{
  "name": "playwright-cucumber",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean:reports": "rimraf test-result && mkdirp test-result",
    "generate:report": "npx ts-node ./src/helper/reportGenerator.ts",
    "pretest": "npm run clean:report",
    "posttest": "npm run generate:report",
    "execute:script": "cucumber-js test",
    "test": "npm run execute:script || npm run posttest",
    "execute:script:failed": "cucumber-js @rerun.txt",
    "test:failed": "npm run execute:script:failed || npm run posttest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "ajv": "^8.20.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "dotenv": "^17.4.2"
  }
}
